  "calculationRules": {
    "addictionScore": {
      "description": "Compute addiction (0-100) from cigarettesPerDay, timeToFirstSmoke, nicotineStrength, yearsSmoking, triggers",
      "formula": "clamp(round((cigarettesPerDay_norm*40) + (timeToFirst_norm*25) + (nicotineStrength_norm*15) + (yearsSmoking_norm*10) + (triggerCount_norm*10)), 0, 100)",
      "normalization": {
        "cigarettesPerDay_norm": "min(cigarettesPerDay / 20, 1)",
        "timeToFirst_norm": "map(timeToFirst) // e.g. within 5min=1, 6-30=0.7, 31-60=0.4, >60=0.1",
        "nicotineStrength_norm": "yes=1,no=0.3,unsure=0.6",
        "yearsSmoking_norm": "min(yearsSmoking / 30, 1)",
        "triggerCount_norm": "min(number_of_selected_triggers / 5, 1)"
      }
    },
    "readinessScore": {
      "description": "Compute recovery potential (0-100) from confidence, support, motivation, pastAttempts (inverted)",
      "formula": "clamp(round((confidence_norm*40) + (support_norm*25) + (motivation_norm*20) + (pastAttempts_norm*15)), 0,100)",
      "normalization": {
        "confidence_norm": "confidence / 5",
        "support_norm": "(support == 'Alone' ? 0.3 : support == 'Partner' ? 0.8 : 0.9)",
        "motivation_norm": "map(motivation) // health=0.9,family=1.0,money=0.8,control=0.7",
        "pastAttempts_norm": "(pastAttempts == 'Never' ? 0.5 : pastAttempts == '1-2' ? 0.6 : pastAttempts == 'Several' ? 0.8 : 0.9)"
      }
    }
  },
