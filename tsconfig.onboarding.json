{
  "compilerOptions": {
    "jsx": "react-native",
    "target": "ES2017",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2017"],
    "types": ["react", "react-native"]
